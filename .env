# LiveKit Configuration
# Get these from your LiveKit Cloud dashboard: https://cloud.livekit.io
LIVEKIT_URL=wss://your-livekit-cloud-url.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# Deepgram STT Configuration
# Get API key from: https://console.deepgram.com
DEEPGRAM_API_KEY=your_deepgram_api_key

# Groq LLM Configuration
# Get API key from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# Cartesia TTS Configuration
# Get API key from: https://cartesia.ai
CARTESIA_API_KEY=your_cartesia_api_key


# Twilio SIP Configuration
# Get these from your Twilio Console: https://console.twilio.com
TWILIO_TRUNK_DOMAIN=your_trunk_domain.sip.twilio.com
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
LIVEKIT_SIP_TRUNK_ID=ST_YOUR_SIP_TRUNK_ID  # Your Twilio SIP Trunk ID in LiveKit


# Optional: Agent Configuration
# Default voice model (alicia, jordan, charlotte, etc.)
# CARTESIA_VOICE=alicia

# Default LLM model (llama-3.3-70b-versatile, mixtral-8x7b-32768, etc.)
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: Logging
# LOG_LEVEL=INFO
